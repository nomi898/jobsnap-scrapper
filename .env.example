# Server
PORT=3000
# Directory for shared jobs/settings (use a persistent disk path on Render/Railway)
DATA_DIR=./data

# Optional — browser prompts for password when opening the site
SITE_PASSWORD=

# Required for cron — GitHub Action sends header x-cron-secret: <value>
CRON_SECRET=

# Optional LinkedIn session cookie (value only, no "li_at=" prefix).
# Used for company page fetches (size, modal details) — NOT for job search.
# Can also be set in Settings UI (saved to server data/store.json).
LI_AT_COOKIE=

# Enable scraper debug logs (optional)
# DEBUG=scraper:info
